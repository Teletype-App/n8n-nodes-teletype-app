{
	"name": "n8n-nodes-teletype-app",
	"version": "0.1.1",
	"description": "Teletype Public API community nodes for n8n.",
	"license": "MIT",
	"homepage": "https://teletype.app/",
	"keywords": [
		"n8n-community-node-package",
		"teletype",
		"teletype-app",
		"api",
		"crm",
		"support",
		"chat"
	],
	"author": {
		"name": "Teletype",
		"email": "p@teletype.app"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Teletype-App/n8n-nodes-teletype-app.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/TeletypeApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Teletype/Teletype.node.js",
			"dist/nodes/TeletypeTrigger/TeletypeTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "^5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
